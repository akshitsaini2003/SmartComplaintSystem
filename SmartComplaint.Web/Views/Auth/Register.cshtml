@model SmartComplaint.Web.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — Smart Complaint System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        [data-theme="dark"] .auth-page {
    background: linear-gradient(135deg, #0F172A 0%, #1E1B4B 100%);
}
[data-theme="dark"] .auth-card {
    background: #1E293B;
    color: #F1F5F9;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
[data-theme="dark"] .auth-card .text-muted { color: #64748B !important; }
[data-theme="dark"] .auth-card .form-label { color: #CBD5E1; }
[data-theme="dark"] .auth-card .form-control,
[data-theme="dark"] .auth-card .form-select {
    background: #0F172A;
    border-color: #334155;
    color: #F1F5F9;
}
[data-theme="dark"] .auth-card .form-control::placeholder { color: #475569; }
[data-theme="dark"] .auth-card .input-group-text {
    background: #263348;
    border-color: #334155;
    color: #94A3B8;
}
[data-theme="dark"] .auth-card hr { border-color: #334155; }
[data-theme="dark"] .auth-card h4 { color: #F1F5F9; }
    </style>
    <script>
            // Apply saved theme before page renders (no flash)
            (function() {
                const t = localStorage.getItem('theme') || 'light';
                document.documentElement.setAttribute('data-theme', t);
            })();
    </script>
</head>

<body>
    <div class="auth-page">
        <div class="auth-card">
            <div class="auth-logo">
                <i class="fas fa-user-plus"></i>
                <h4>Create Account</h4>
                <p class="text-muted" style="font-size:13px">Fill in your details to get started</p>
            </div>

            <form method="post" id="regForm">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-user text-muted"></i></span>
                        <input asp-for="Name" class="form-control" placeholder="John Doe" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                        <input asp-for="Email" type="email" class="form-control"
                               placeholder="you@example.com" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control"
                               placeholder="Min 6 characters" required minlength="6" id="passInput" />
                        <button type="button" class="input-group-text" onclick="togglePass()">
                            <i class="fas fa-eye text-muted" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2" id="regBtn">
                    <i class="fas fa-user-plus me-2"></i>Create Account
                </button>

                <hr class="my-3" />
                <p class="text-center text-muted mb-0" style="font-size:13px">
                    Already have an account?
                    <a href="/Auth/Login" class="text-primary fw-semibold">Sign In</a>
                </p>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        toastr.options = { positionClass:"toast-top-right", timeOut:4000, closeButton:true };

        @if (TempData["Error"] != null)
        {
            <text>toastr.error('@TempData["Error"]');</text>
        }

        $('#regForm').on('submit', function() {
        $('#regBtn').html('<i class="fas fa-spinner fa-spin me-2"></i>Creating...')
        .prop('disabled', true);
        });

        function togglePass() {
        const input = document.getElementById('passInput');
        const icon  = document.getElementById('eyeIcon');
        input.type = input.type === 'password' ? 'text' : 'password';
        icon.classList.toggle('fa-eye');
        icon.classList.toggle('fa-eye-slash');
        }
    </script>
</body>
</html>