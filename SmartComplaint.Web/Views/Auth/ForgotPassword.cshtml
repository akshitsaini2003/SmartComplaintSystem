@model SmartComplaint.Web.Models.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        [data-theme="dark"] .auth-page {
    background: linear-gradient(135deg, #0F172A 0%, #1E1B4B 100%);
}
[data-theme="dark"] .auth-card {
    background: #1E293B;
    color: #F1F5F9;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
[data-theme="dark"] .auth-card .text-muted { color: #64748B !important; }
[data-theme="dark"] .auth-card .form-label { color: #CBD5E1; }
[data-theme="dark"] .auth-card .form-control,
[data-theme="dark"] .auth-card .form-select {
    background: #0F172A;
    border-color: #334155;
    color: #F1F5F9;
}
[data-theme="dark"] .auth-card .form-control::placeholder { color: #475569; }
[data-theme="dark"] .auth-card .input-group-text {
    background: #263348;
    border-color: #334155;
    color: #94A3B8;
}
[data-theme="dark"] .auth-card hr { border-color: #334155; }
[data-theme="dark"] .auth-card h4 { color: #F1F5F9; }
    </style>
    <script>
            // Apply saved theme before page renders (no flash)
            (function() {
                const t = localStorage.getItem('theme') || 'light';
                document.documentElement.setAttribute('data-theme', t);
            })();
    </script>
</head>
<body>
    <div class="auth-page">
        <div class="auth-card">
            <div class="auth-logo">
                <i class="fas fa-key"></i>
                <h4>Forgot Password?</h4>
                <p class="text-muted" style="font-size:13px">
                    Enter your email and we'll send you a reset link
                </p>
            </div>

            <form method="post" id="fpForm">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                        <input asp-for="Email" type="email" class="form-control"
                               placeholder="you@example.com" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2" id="fpBtn">
                    <i class="fas fa-paper-plane me-2"></i>Send Reset Link
                </button>
            </form>

            <div class="text-center mt-3">
                <a href="/Auth/Login" class="text-muted" style="font-size:13px">
                    <i class="fas fa-arrow-left me-1"></i>Back to Login
                </a>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        toastr.options = { positionClass:"toast-top-right", timeOut:5000, closeButton:true };

        @if (TempData["Error"] != null)
        {
            <text>toastr.error('@TempData["Error"]');</text>
        }
        @if (TempData["Success"] != null)
        {
            <text>toastr.success('@TempData["Success"]');</text>
        }

        $('#fpForm').on('submit', function() {
        $('#fpBtn').html('<i class="fas fa-spinner fa-spin me-2"></i>Sending...')
        .prop('disabled', true);
        });
    </script>
</body>
</html>