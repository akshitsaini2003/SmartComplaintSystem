@model SmartComplaint.Web.Models.AdminDashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <h2><i class="fas fa-chart-pie me-2 text-primary"></i>Admin Dashboard</h2>
    <p>System overview — @DateTime.Now.ToString("MMMM dd, yyyy")</p>
</div>

<!-- Stat Cards Row 1 -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Total Complaints</div>
                    <div class="stat-value">@Model.TotalComplaints</div>
                </div>
                <div class="stat-icon" style="background:#EEF2FF">
                    <i class="fas fa-file-alt text-primary fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Open</div>
                    <div class="stat-value" style="color:#1D4ED8">@Model.OpenComplaints</div>
                </div>
                <div class="stat-icon" style="background:#DBEAFE">
                    <i class="fas fa-folder-open fa-lg" style="color:#1D4ED8"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Resolved Today</div>
                    <div class="stat-value" style="color:#059669">@Model.ResolvedToday</div>
                </div>
                <div class="stat-icon" style="background:#D1FAE5">
                    <i class="fas fa-check-circle fa-lg" style="color:#059669"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">SLA Breaches</div>
                    <div class="stat-value" style="color:#DC2626">@Model.SlaBreaches</div>
                </div>
                <div class="stat-icon" style="background:#FEE2E2">
                    <i class="fas fa-exclamation-triangle fa-lg" style="color:#DC2626"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stat Cards Row 2 -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">In Progress</div>
                    <div class="stat-value" style="color:#B45309">
                        @Model.InProgressComplaints
                    </div>
                </div>
                <div class="stat-icon" style="background:#FEF3C7">
                    <i class="fas fa-spinner fa-lg" style="color:#B45309"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Closed</div>
                    <div class="stat-value" style="color:#4B5563">@Model.ClosedComplaints</div>
                </div>
                <div class="stat-icon" style="background:#F3F4F6">
                    <i class="fas fa-lock fa-lg" style="color:#4B5563"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Avg Resolution</div>
                    <div class="stat-value" style="color:#7C3AED">
                        @Model.AverageResolutionHours.ToString("F1")h
                    </div>
                </div>
                <div class="stat-icon" style="background:#EDE9FE">
                    <i class="fas fa-clock fa-lg" style="color:#7C3AED"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Total Agents</div>
                    <div class="stat-value" style="color:#0891B2">
                        @Model.TopAgents.Count
                    </div>
                </div>
                <div class="stat-icon" style="background:#CFFAFE">
                    <i class="fas fa-user-tie fa-lg" style="color:#0891B2"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">

    <!-- Category Doughnut -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-chart-pie me-2"></i>Complaints by Category
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                @if (Model.ComplaintsByCategory.Any())
                {
                    <canvas id="categoryChart" style="max-height:260px"></canvas>
                }
                else
                {
                    <p class="text-muted">No data yet</p>
                }
            </div>
        </div>
    </div>

    <!-- Priority Bar -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-chart-bar me-2"></i>Complaints by Priority
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                @if (Model.ComplaintsByPriority.Any())
                {
                    <canvas id="priorityChart" style="max-height:260px"></canvas>
                }
                else
                {
                    <p class="text-muted">No data yet</p>
                }
            </div>
        </div>
    </div>

    <!-- Status Doughnut -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-chart-donut me-2"></i>Complaints by Status
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="statusChart" style="max-height:260px"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Top Agents Table -->
<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                <span><i class="fas fa-trophy me-2 text-warning"></i>Top Agents</span>
                <a href="/Users/Agents" class="btn btn-sm btn-outline-primary">
                    View All
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.TopAgents.Any())
                {
                    <p class="text-muted text-center py-4">No agent data yet</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Rank</th>
                                <th>Agent</th>
                                <th>Resolved</th>
                                <th>Performance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rank = 1;
                            }
                            @foreach (var a in Model.TopAgents)
                            {
                                var medal = rank switch
                                {
                                    1 => "🥇",
                                    2 => "🥈",
                                    3 => "🥉",
                                    _ => $"#{rank}"
                                };
                                var maxResolved = Model.TopAgents.Max(x => x.ResolvedCount);
                                var pct = maxResolved > 0
                                    ? (int)((double)a.ResolvedCount / maxResolved * 100)
                                    : 0;
                                <tr>
                                    <td><span style="font-size:18px">@medal</span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary text-white
                                                d-flex align-items-center
                                                justify-content-center"
                                                 style="width:30px;height:30px;
                                                font-size:12px;font-weight:600">
                                                @a.AgentName[0].ToString().ToUpper()
                                            </div>
                                            <span style="font-size:13px">@a.AgentName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge badge-resolved">
                                            @a.ResolvedCount resolved
                                        </span>
                                    </td>
                                    <td style="width:140px">
                                        <div class="progress" style="height:6px">
                                            <div class="progress-bar bg-primary"
                                                 style="width:@pct%"></div>
                                        </div>
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-bolt me-2"></i>Quick Actions
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a href="/Complaints/Index" class="btn btn-outline-primary text-start">
                    <i class="fas fa-file-alt me-2"></i>View All Complaints
                </a>
                <a href="/Users/Index" class="btn btn-outline-primary text-start">
                    <i class="fas fa-users me-2"></i>Manage Users
                </a>
                <a href="/Assignments/Index" class="btn btn-outline-primary text-start">
                    <i class="fas fa-user-check me-2"></i>Manage Assignments
                </a>
                <a href="/Dashboard/Reports" class="btn btn-outline-primary text-start">
                    <i class="fas fa-chart-bar me-2"></i>View Reports
                </a>
                <a href="/Feedback/Report" class="btn btn-outline-primary text-start">
                    <i class="fas fa-star me-2"></i>Feedback Report
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // ── Category Doughnut ──────────────────────────────
        @if (Model.ComplaintsByCategory.Any())
        {
            <text>
                new Chart(document.getElementById('categoryChart'), {
                type: 'doughnut',
                data: {
                labels: [@Html.Raw(string.Join(",",
                                    Model.ComplaintsByCategory.Select(c => $"'{c.CategoryName}'")))],
                datasets: [{
                data: [@string.Join(",",
                                        Model.ComplaintsByCategory.Select(c => c.Count))],
                backgroundColor: [
                '#6366F1','#0EA5E9','#10B981',
                '#F59E0B','#EF4444','#8B5CF6'
                ],
                borderWidth: 2,
                borderColor: '#fff'
                }]
                },
                options: {
                responsive: true,
                plugins: {
                legend: { position: 'bottom', labels: { font: { size: 11 } } }
                }
                }
                });
            </text>
        }

        // ── Priority Bar ───────────────────────────────────
        @if (Model.ComplaintsByPriority.Any())
        {
            <text>
                new Chart(document.getElementById('priorityChart'), {
                type: 'bar',
                data: {
                labels: [@Html.Raw(string.Join(",",
                                    Model.ComplaintsByPriority.Select(p => $"'{p.Priority}'")))],
                datasets: [{
                label: 'Complaints',
                data: [@string.Join(",",
                                        Model.ComplaintsByPriority.Select(p => p.Count))],
                backgroundColor: ['#EF4444','#F59E0B','#10B981'],
                borderRadius: 6,
                borderSkipped: false
                }]
                },
                options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                y: {
                beginAtZero: true,
                ticks: { stepSize: 1 },
                grid: { color: '#F1F5F9' }
                },
                x: { grid: { display: false } }
                }
                }
                });
            </text>
        }

        // ── Status Doughnut ────────────────────────────────
        new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
        labels: ['Open','In Progress','On Hold','Resolved','Closed'],
        datasets: [{
        data: [
        @Model.OpenComplaints,
        @Model.InProgressComplaints,
        0,
        @Model.ResolvedToday,
        @Model.ClosedComplaints
        ],
        backgroundColor: [
        '#DBEAFE','#FEF3C7','#F3F4F6','#D1FAE5','#E5E7EB'
        ],
        borderColor: [
        '#1D4ED8','#B45309','#6B7280','#059669','#4B5563'
        ],
        borderWidth: 2
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { position: 'bottom', labels: { font: { size: 11 } } }
        }
        }
        });
    </script>
}