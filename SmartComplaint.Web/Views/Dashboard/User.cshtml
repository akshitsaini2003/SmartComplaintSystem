@model SmartComplaint.Web.Models.UserDashboardModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="page-header">
    <h2><i class="fas fa-home me-2 text-primary"></i>My Dashboard</h2>
    <p>Welcome back, @User.Identity?.Name!</p>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Total Complaints</div>
                    <div class="stat-value">@Model.TotalComplaints</div>
                </div>
                <div class="stat-icon" style="background:#EEF2FF">
                    <i class="fas fa-file-alt fa-lg text-primary"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Open / Pending</div>
                    <div class="stat-value" style="color:#1D4ED8">
                        @Model.OpenComplaints
                    </div>
                </div>
                <div class="stat-icon" style="background:#DBEAFE">
                    <i class="fas fa-folder-open fa-lg" style="color:#1D4ED8"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Resolved</div>
                    <div class="stat-value" style="color:#059669">
                        @Model.ResolvedComplaints
                    </div>
                </div>
                <div class="stat-icon" style="background:#D1FAE5">
                    <i class="fas fa-check-circle fa-lg" style="color:#059669"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">My Avg Rating</div>
                    <div class="stat-value" style="color:#F59E0B">
                        @(Model.AverageFeedbackRating > 0
                            ? Model.AverageFeedbackRating.ToString("F1") + " ★"
                            : "—")
                    </div>
                </div>
                <div class="stat-icon" style="background:#FEF3C7">
                    <i class="fas fa-star fa-lg" style="color:#F59E0B"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chart + Actions -->
<div class="row g-3">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-chart-pie me-2"></i>My Complaint Status
            </div>
            <div class="card-body d-flex justify-content-center">
                <canvas id="userChart" style="max-height:220px;max-width:220px"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-bolt me-2"></i>Quick Actions
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a href="/Complaints/Create" class="btn btn-primary text-start">
                    <i class="fas fa-plus me-2"></i>Submit New Complaint
                </a>
                <a href="/Complaints/My" class="btn btn-outline-primary text-start">
                    <i class="fas fa-list me-2"></i>View My Complaints
                </a>
                <a href="/Notifications" class="btn btn-outline-primary text-start">
                    <i class="fas fa-bell me-2"></i>My Notifications
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        new Chart(document.getElementById('userChart'), {
        type: 'doughnut',
        data: {
        labels: ['Open / Pending', 'Resolved'],
        datasets: [{
        data: [@Model.OpenComplaints, @Model.ResolvedComplaints],
        backgroundColor: ['#DBEAFE', '#D1FAE5'],
        borderColor:     ['#1D4ED8', '#059669'],
        borderWidth: 2
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { position: 'bottom', labels: { font: { size: 12 } } }
        }
        }
        });
    </script>
}