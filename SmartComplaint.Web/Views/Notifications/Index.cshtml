@model List<SmartComplaint.Web.Models.NotificationModel>
@{
    ViewData["Title"] = "Notifications";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="fas fa-bell me-2 text-primary"></i>Notifications</h2>
        <p>Your recent notifications</p>
    </div>
    @if (Model.Any(n => !n.IsRead))
    {
        <a href="/Notifications/MarkAllRead" class="btn btn-outline-primary btn-sm">
            <i class="fas fa-check-double me-1"></i>Mark All Read
        </a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-bell-slash fa-3x mb-3 d-block"></i>
                No notifications yet
            </div>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var n in Model.OrderByDescending(x => x.CreatedDate))
                {
                    <li class="list-group-item d-flex justify-content-between align-items-start py-3"
                        style="background:@(n.IsRead ? "transparent" : "#F0F4FF")">
                        <div class="d-flex gap-3">
                            <div class="mt-1">
                                <i class="fas fa-circle @(n.IsRead ? "text-muted" : "text-primary")"
                                   style="font-size:8px"></i>
                            </div>
                            <div>
                                <p class="mb-1 @(n.IsRead ? "text-muted" : "fw-semibold")"
                                   style="font-size:14px">@n.Message</p>
                                <small class="text-muted">
                                    <i class="fas fa-clock me-1"></i>
                                    @n.CreatedDate.ToString("MMM dd, yyyy hh:mm tt")
                                </small>
                            </div>
                        </div>
                        <div class="d-flex gap-2 ms-3">
                            @if (!n.IsRead)
                            {
                                <a href="/Notifications/MarkRead/@n.NotificationId"
                                       class="btn btn-sm btn-outline-success"
                                       title="Mark as read">
                                    <i class="fas fa-check"></i>
                                </a>
                            }
                            <a href="/Notifications/Delete/@n.NotificationId"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Delete this notification?')"
                                   title="Delete">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>