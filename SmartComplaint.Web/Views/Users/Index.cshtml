@model List<SmartComplaint.Web.Models.UserModel>
@{
    ViewData["Title"] = "User Management";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="fas fa-users me-2 text-primary"></i>User Management</h2>
        <p>Manage all system users</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
        <i class="fas fa-user-plus me-2"></i>Add User
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Verified</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td><span class="text-muted">@u.UserId</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-primary text-white d-flex
                                        align-items-center justify-content-center"
                                         style="width:32px;height:32px;font-size:12px;font-weight:600;flex-shrink:0">
                                        @u.Name[0].ToString().ToUpper()
                                    </div>
                                    <span class="fw-semibold" style="font-size:13px">@u.Name</span>
                                </div>
                            </td>
                            <td><small class="text-muted">@u.Email</small></td>
                            <td>
                                @{
                                    var rClass = u.Role switch
                                    {
                                        "Admin" => "bg-danger",
                                        "Agent" => "bg-warning text-dark",
                                        _ => "bg-primary"
                                    };
                                }
                                <span class="badge @rClass">@u.Role</span>
                            </td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge badge-resolved">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-closed">Inactive</span>
                                }
                            </td>
                            <td>
                                @if (u.IsEmailVerified)
                                {
                                    <i class="fas fa-check-circle text-success"></i>
                                }
                                else
                                {
                                    <i class="fas fa-times-circle text-danger"></i>
                                }
                            </td>
                            <td><small class="text-muted">@u.CreatedDate.ToString("MMM dd, yyyy")</small></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-outline-warning"
                                            title="Change Role"
                                            onclick="openRoleModal(@u.UserId, '@u.Name', '@u.Role')">
                                        <i class="fas fa-user-tag"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-info"
                                            title="Edit"
                                            onclick="openEditModal(@u.UserId, '@u.Name', @u.IsActive.ToString().ToLower())">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            title="Deactivate"
                                            onclick="confirmDeactivate(@u.UserId, '@u.Name')">
                                        <i class="fas fa-user-slash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="/Users?page=@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">
                    <i class="fas fa-user-plus me-2"></i>Create New User
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Users/Create">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="Name" class="form-control"
                               placeholder="John Doe" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" class="form-control"
                               placeholder="john@example.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="Password" class="form-control"
                               placeholder="Min 6 characters" required minlength="6" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select name="Role" class="form-select">
                            <option value="User">User</option>
                            <option value="Agent">Agent</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fas fa-save me-2"></i>Create User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="fas fa-edit me-2"></i>Edit User</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Users/Update" id="editUserForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editUserId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" name="name" id="editUserName"
                               class="form-control" required />
                    </div>
                    <div class="form-check">
                        <input type="checkbox" name="isActive" id="editIsActive"
                               class="form-check-input" value="true" />
                        <label class="form-check-label">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Change Role Modal -->
<div class="modal fade" id="roleModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">
                    <i class="fas fa-user-tag me-2"></i>Change Role
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Users/UpdateRole">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="roleUserId" />
                <div class="modal-body">
                    <p class="text-muted small" id="roleUserLabel"></p>
                    <select name="role" class="form-select" id="roleSelect">
                        <option value="User">User</option>
                        <option value="Agent">Agent</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-warning btn-sm">Update Role</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openRoleModal(id, name, currentRole) {
            document.getElementById('roleUserId').value    = id;
            document.getElementById('roleUserLabel').textContent = 'Changing role for: ' + name;
            document.getElementById('roleSelect').value    = currentRole;
            new bootstrap.Modal(document.getElementById('roleModal')).show();
        }

        function openEditModal(id, name, isActive) {
            document.getElementById('editUserId').value   = id;
            document.getElementById('editUserName').value = name;
            document.getElementById('editIsActive').checked = isActive;
            new bootstrap.Modal(document.getElementById('editUserModal')).show();
        }

        function confirmDeactivate(id, name) {
            Swal.fire({
                title: 'Deactivate ' + name + '?',
                text: 'User will be set as inactive.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#EF4444',
                confirmButtonText: 'Deactivate'
            }).then(r => {
                if (r.isConfirmed) window.location.href = '/Users/Delete/' + id;
            });
        }
    </script>
}