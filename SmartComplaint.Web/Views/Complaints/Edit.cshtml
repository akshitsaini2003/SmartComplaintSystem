@model SmartComplaint.Web.Models.UpdateComplaintModel
@{
    ViewData["Title"] = "Edit Complaint";
    var categories = ViewBag.Categories as List<SmartComplaint.Web.Models.CategoryModel>
                      ?? new List<SmartComplaint.Web.Models.CategoryModel>();
    int complaintId = ViewBag.ComplaintId ?? 0;
}

<div class="page-header">
    <h2><i class="fas fa-edit me-2 text-warning"></i>Edit Complaint #@complaintId</h2>
    <p>Update the complaint details below</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-pen me-2"></i>Edit Details
            </div>
            <div class="card-body">
                <form method="post" id="editForm">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Title</label>
                        <input asp-for="Title" class="form-control" required maxlength="200" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control"
                                  rows="5" required></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category</label>
                        <select asp-for="CategoryId" class="form-select" required>
                            <option value="">— Select Category —</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.CategoryId">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/Complaints/Detail/@complaintId"
                               class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-warning" id="saveBtn">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["Error"] != null)
        {
                <text>toastr.error('@TempData["Error"]');</text>
        }
        $('#editForm').on('submit', function() {
            $('#saveBtn').html('<i class="fas fa-spinner fa-spin me-2"></i>Saving...')
                         .prop('disabled', true);
        });
    </script>
}
