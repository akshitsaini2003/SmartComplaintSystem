@model SmartComplaint.Web.Models.ComplaintDetailModel
@{
    ViewData["Title"] = "Complaint Detail";
    var comments    = ViewBag.Comments    as List<SmartComplaint.Web.Models.CommentModel>
                      ?? new List<SmartComplaint.Web.Models.CommentModel>();
    var attachments = ViewBag.Attachments as List<SmartComplaint.Web.Models.AttachmentModel>
                      ?? new List<SmartComplaint.Web.Models.AttachmentModel>();

    var sClass = Model.Status switch {
        "Open"       => "badge-open",
        "InProgress" => "badge-inprogress",
        "OnHold"     => "badge-onhold",
        "Resolved"   => "badge-resolved",
        _            => "badge-closed"
    };
    var pClass = Model.Priority switch {
        "High"   => "badge-high",
        "Medium" => "badge-medium",
        _        => "badge-low"
    };
}

<!-- Page Header -->
<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <div class="d-flex align-items-center gap-2 mb-1">
            <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="mb-0">Complaint #@Model.ComplaintId</h2>
            <span class="badge @sClass fs-6">@Model.Status</span>
            <span class="badge @pClass">@Model.Priority</span>
        </div>
        <p class="text-muted ms-5">
            Submitted by @Model.UserName on @Model.CreatedDate.ToString("MMMM dd, yyyy")
        </p>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("Agent"))
    {
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#statusModal">
            <i class="fas fa-exchange-alt me-2"></i>Update Status
        </button>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3">
    <!-- Left Column -->
    <div class="col-lg-8">

        <!-- Complaint Info -->
        <div class="card mb-3">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>Complaint Information
            </div>
            <div class="card-body">
                <h5 class="fw-semibold mb-3">@Model.Title</h5>
                <p class="text-muted" style="line-height:1.7">@Model.Description</p>
                <hr/>
                <div class="row g-2">
                    <div class="col-sm-4">
                        <small class="text-muted d-block">Category</small>
                        <span class="badge bg-light text-dark border">@Model.CategoryName</span>
                    </div>
                    <div class="col-sm-4">
                        <small class="text-muted d-block">Submitted By</small>
                        <strong>@Model.UserName</strong>
                    </div>
                    <div class="col-sm-4">
                        <small class="text-muted d-block">Email</small>
                        <small>@Model.UserEmail</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Comments -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between">
                <span><i class="fas fa-comments me-2"></i>Comments (@comments.Count)</span>
            </div>
            <div class="card-body">
                @if (!comments.Any())
                {
                    <p class="text-muted text-center py-2">
                        <i class="fas fa-comment-slash me-2"></i>No comments yet
                    </p>
                }
                @foreach (var cm in comments)
                {
                    <div class="d-flex gap-3 mb-3 pb-3 border-bottom">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center
                                    justify-content-center flex-shrink-0"
                             style="width:36px;height:36px;font-size:13px;font-weight:600">
                            @cm.UserName[0].ToString().ToUpper()
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <strong style="font-size:13px">@cm.UserName</strong>
                                <small class="text-muted">
                                    @cm.CreatedDate.ToString("MMM dd, hh:mm tt")
                                </small>
                            </div>
                            <p class="mb-0 mt-1" style="font-size:14px">@cm.Message</p>
                        </div>
                        <button class="btn btn-sm btn-outline-danger align-self-start"
                                onclick="deleteComment(@cm.CommentId, @Model.ComplaintId)">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                }

                <!-- Add Comment -->
                <form method="post" action="/Complaints/AddComment" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="complaintId" value="@Model.ComplaintId"/>
                    <div class="input-group">
                        <textarea name="message" class="form-control" rows="2"
                                  placeholder="Write a comment..." required
                                  style="resize:none"></textarea>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Attachments -->
        <div class="card">
            <div class="card-header">
                <i class="fas fa-paperclip me-2"></i>Attachments (@attachments.Count)
            </div>
            <div class="card-body">
                @if (attachments.Any())
                {
                    <div class="list-group list-group-flush mb-3">
                        @foreach (var att in attachments)
                        {
                            <div class="list-group-item d-flex justify-content-between
                                        align-items-center px-0">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-file text-primary"></i>
                                    <span style="font-size:13px">@att.FileName</span>
                                    <small class="text-muted">
                                        @att.UploadedDate.ToString("MMM dd")
                                    </small>
                                </div>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a href="/Complaints/DeleteAttachment/@att.AttachmentId/@Model.ComplaintId"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Delete this file?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Upload Form -->
                <form method="post" action="/Complaints/UploadAttachment"
                      enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="complaintId" value="@Model.ComplaintId"/>
                    <div class="input-group">
                        <input type="file" name="file" class="form-control"
                               accept=".jpg,.jpeg,.png,.pdf,.docx" required/>
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="fas fa-upload me-1"></i>Upload
                        </button>
                    </div>
                    <div class="form-text">
                        Allowed: jpg, jpeg, png, pdf, docx (max 5MB)
                    </div>
                </form>
            </div>
        </div>

    </div>

    <!-- Right Column -->
    <div class="col-lg-4">

        <!-- Status Card -->
        <!-- Status Card -->
        <div class="card mb-3">
            <div class="card-header">
                <i class="fas fa-history me-2"></i>Status Timeline
            </div>
            <div class="card-body p-0">
                @{
                    var allStatuses = new[] { "Open", "InProgress", "OnHold", "Resolved", "Closed" };

                    var history = ViewBag.History as List<SmartComplaint.Web.Models.ComplaintHistoryModel>
                                  ?? new List<SmartComplaint.Web.Models.ComplaintHistoryModel>();

                    var currentIdx = Array.IndexOf(allStatuses, Model.Status);

                    // Har status ka timestamp dictionary
                    var timestamps = new Dictionary<string, DateTime?>();
                    var changedByMap = new Dictionary<string, string>();

                    // Open = complaint created date (hamesha available)
                    timestamps["Open"] = Model.CreatedDate;
                    changedByMap["Open"] = Model.UserName;

                    // History se baaki statuses
                    foreach (var h in history.OrderBy(x => x.ChangedDate))
                    {
                        if (!string.IsNullOrEmpty(h.NewStatus))
                        {
                            timestamps[h.NewStatus] = h.ChangedDate;
                            changedByMap[h.NewStatus] = h.ChangedBy;
                        }
                    }
                }

                <ul class="list-unstyled mb-0">
                    @foreach (var (st, idx) in allStatuses.Select((s, i) => (s, i)))
                    {
                        var isDone = idx <= currentIdx;
                        var isCurrent = st == Model.Status;
                        var hasTime = timestamps.ContainsKey(st) && timestamps[st].HasValue;
                        var ts = hasTime ? timestamps[st]!.Value : (DateTime?)null;
                        var changedBy = changedByMap.ContainsKey(st) ? changedByMap[st] : "";

                        var dotBg = isCurrent ? "#4F46E5"
                                  : isDone ? "#10B981"
                                  : "#E2E8F0";

                        var iconClass = isDone && !isCurrent ? "fas fa-check"
                                      : isCurrent ? "fas fa-circle"
                                      : "far fa-circle";

                        var dotColor = isDone || isCurrent ? "#fff" : "#94A3B8";

                        var lineColor = isDone && idx < currentIdx ? "#10B981" : "#E2E8F0";

                        var Class = st switch
                        {
                            "Open" => "badge-open",
                            "InProgress" => "badge-inprogress",
                            "OnHold" => "badge-onhold",
                            "Resolved" => "badge-resolved",
                            _ => "badge-closed"
                        };

                        <li style="display:flex;align-items:flex-start;
                            padding:14px 18px;
                            background:@(isCurrent ? "rgba(79,70,229,0.04)" : "transparent");
                            @(idx < allStatuses.Length - 1 ? "border-bottom:1px solid #F1F5F9;" : "")">

                            <!-- Dot + Connector Line -->
                            <div style="display:flex;flex-direction:column;align-items:center;
                                margin-right:14px;flex-shrink:0">
                                <div style="width:34px;height:34px;border-radius:50%;
                                    background:@dotBg;flex-shrink:0;
                                    display:flex;align-items:center;justify-content:center;
                                    box-shadow:@(isCurrent ? "0 0 0 4px rgba(79,70,229,0.15)" : isDone ? "0 0 0 3px rgba(16,185,129,0.15)" : "none");
                                    transition:all .3s ease">
                                    <i class="@iconClass" style="font-size:12px;color:@dotColor"></i>
                                </div>
                                @if (idx < allStatuses.Length - 1)
                                {
                                    <div style="width:2px;min-height:24px;flex:1;
                                        background:@lineColor;
                                        margin-top:3px;border-radius:1px;
                                        transition:background .3s ease">
                                    </div>
                                }
                            </div>

                            <!-- Status Info -->
                            <div style="flex:1;padding-top:5px">

                                <!-- Status Name + Badge -->
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
                                    <span style="font-size:14px;
                                        font-weight:@(isCurrent ? "700" : isDone ? "600" : "400");
                                        color:@(isCurrent ? "#4F46E5" : isDone ? "#1E293B" : "#94A3B8")">
                                        @(st == "InProgress" ? "In Progress" : st)
                                    </span>
                                    @if (isCurrent)
                                    {
                                        <span class="badge @sClass" style="font-size:9px;padding:3px 7px">
                                            Current
                                        </span>
                                    }
                                    @if (isDone && !isCurrent)
                                    {
                                        <span style="font-size:10px;color:#10B981;font-weight:500">
                                            ✓ Done
                                        </span>
                                    }
                                </div>

                                @if (hasTime && ts.HasValue)
                                {
                                    <!-- Timestamp -->
                                    <div style="display:flex;align-items:center;gap:6px;
                                        font-size:11px;color:#64748B;margin-bottom:3px">
                                        <i class="fas fa-calendar-alt" style="color:#94A3B8;font-size:10px"></i>
                                        <span style="font-weight:500">
                                            @ts.Value.ToString("MMM dd, yyyy")
                                        </span>
                                        <span style="color:#CBD5E1">•</span>
                                        <i class="fas fa-clock" style="color:#94A3B8;font-size:10px"></i>
                                        <span>@ts.Value.ToString("hh:mm tt")</span>
                                    </div>

                                    <!-- Changed By -->
                                    @if (!string.IsNullOrEmpty(changedBy))
                                    {
                                        <div style="display:flex;align-items:center;gap:5px;
                                            font-size:11px;color:#94A3B8">
                                            <i class="fas fa-user-circle" style="font-size:10px"></i>
                                            <span>
                                                @(st == "Open" ? "Submitted by" : "Updated by")
                                                <strong style="color:#64748B">@changedBy</strong>
                                            </span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div style="font-size:11px;color:#CBD5E1;
                                        display:flex;align-items:center;gap:5px">
                                        <i class="fas fa-minus" style="font-size:9px"></i>
                                        <span>Pending</span>
                                    </div>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
        <!-- Quick Info -->
        <div class="card">
            <div class="card-header">
                <i class="fas fa-clipboard me-2"></i>Quick Info
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="font-size:12px">Complaint ID</td>
                        <td class="fw-semibold" style="font-size:12px">#@Model.ComplaintId</td>
                    </tr>
                    <tr>
                        <td class="text-muted" style="font-size:12px">Category</td>
                        <td style="font-size:12px">@Model.CategoryName</td>
                    </tr>
                    <tr>
                        <td class="text-muted" style="font-size:12px">Priority</td>
                        <td><span class="badge @pClass" style="font-size:10px">@Model.Priority</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted" style="font-size:12px">Status</td>
                        <td><span class="badge @sClass" style="font-size:10px">@Model.Status</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted" style="font-size:12px">Submitted</td>
                        <td style="font-size:12px">@Model.CreatedDate.ToString("MMM dd, yyyy")</td>
                    </tr>
                </table>

                @if (User.IsInRole("Admin"))
                {
                    <hr/>
                    <a href="/Complaints/Edit/@Model.ComplaintId"
                       class="btn btn-outline-warning btn-sm w-100 mb-2">
                        <i class="fas fa-edit me-2"></i>Edit Complaint
                    </a>
                    <button class="btn btn-outline-danger btn-sm w-100"
                            onclick="confirmDelete(@Model.ComplaintId)">
                        <i class="fas fa-trash me-2"></i>Delete Complaint
                    </button>
                }
                @* Feedback button for resolved complaints (User role) *@
                @if (User.IsInRole("User") &&
                     (Model.Status == "Resolved" || Model.Status == "Closed"))
                {
                    <hr />
                    <a href="/Feedback/Submit?id=@Model.ComplaintId">

                        <i class="fas fa-star me-2"></i>Rate This Resolution
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<!-- Status Update Modal -->
@if (User.IsInRole("Admin") || User.IsInRole("Agent"))
{
    <div class="modal fade" id="statusModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title">
                        <i class="fas fa-exchange-alt me-2"></i>Update Status
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="/Complaints/UpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ComplaintId"/>
                    <div class="modal-body">
                        <p class="text-muted small mb-2">
                            Current: <span class="badge @sClass">@Model.Status</span>
                        </p>
                        <label class="form-label">New Status</label>
                        <select name="status" class="form-select">
                            @foreach (var s in new[]{"Open","InProgress","OnHold","Resolved","Closed"})
                            {
                                @* <option value="@s" @(s == Model.Status ? "selected" : "")>@s</option> *@
                                <option value="@s" selected="@(s == Model.Status)">
                                    @s
                                </option>
                            }
                        </select>
                        <div class="form-text mt-2">
                            <i class="fas fa-info-circle me-1"></i>
                            Invalid transitions will be rejected by the server.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm"
                                data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary btn-sm">
                            Update
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
function confirmDelete(id) {
    Swal.fire({
        title: 'Delete Complaint?',
        text: 'This cannot be undone.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#EF4444',
        confirmButtonText: 'Yes, delete!'
    }).then(r => {
        if (r.isConfirmed) window.location.href = '/Complaints/Delete/' + id;
    });
}

function deleteComment(commentId, complaintId) {
    Swal.fire({
        title: 'Delete Comment?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#EF4444',
        confirmButtonText: 'Delete'
    }).then(r => {
        if (r.isConfirmed)
            window.location.href = `/Complaints/DeleteComment/${commentId}/${complaintId}`;
    });
}
</script>
}